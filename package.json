    "magicast": "^0.3.5",
    "pg": "^8.16.3",
    "posthog-js": "^1.292.0",
    "radix-vue": "^1.9.17"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@iconify/json": "^2.2.406",
