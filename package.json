{
  "name": "nuxt-flutter-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "pnpm --parallel --filter web --filter asodb dev",
    "dev:db": "pnpm --filter asodb dev",
    "build": "pnpm --filter web build",
    "generate": "pnpm --filter web generate",
    "preview": "pnpm --filter web preview",
    "lint": "pnpm --filter web lint",
    "lint:fix": "pnpm --filter web lint:fix",
    "db:migrate": "pnpm --filter web db:migrate",
    "db:migrate:generate": "pnpm --filter web db:migrate:generate",
    "test": "pnpm --filter web test",
    "test:watch": "pnpm --filter web test:watch",
    "test:e2e": "pnpm --filter web test:e2e",
    "test:components": "pnpm --filter web test:components"
  }
}
