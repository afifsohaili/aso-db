{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "strict": true,
    "noEmit": true,
    "types": [
      "node"
    ],
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "bin/**/*.ts",
    "src/**/*.ts",
    "test/**/*.ts",
    "vitest.config.ts"
  ]
}
